#!/bin/bash
# AppImage entry point — sets up all env vars then launches the app.

export APPDIR="$(dirname "$(readlink -f "${0}")")"
export PATH="$APPDIR/usr/bin:${PATH}"
export LD_LIBRARY_PATH="$APPDIR/usr/lib/x86_64-linux-gnu:$APPDIR/usr/lib:${LD_LIBRARY_PATH}"
export GI_TYPELIB_PATH="$APPDIR/usr/lib/x86_64-linux-gnu/girepository-1.0"
export XDG_DATA_DIRS="$APPDIR/usr/share:${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"
export GSETTINGS_SCHEMA_DIR="$APPDIR/usr/share/glib-2.0/schemas"

# Build PYTHONPATH: bundled site-packages + app source + vendor inside AppImage
_PYVER=$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')
export PYTHONPATH="\
$APPDIR/usr/lib/python3/dist-packages:\
$APPDIR/usr/lib/python${_PYVER}/dist-packages:\
$APPDIR/usr/share/restic-box:\
$APPDIR/usr/share/restic-box/vendor:\
${PYTHONPATH}"

exec "$APPDIR/usr/bin/python3" "$APPDIR/usr/share/restic-box/main.py" "$@"
